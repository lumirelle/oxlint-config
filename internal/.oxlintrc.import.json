{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "plugins": ["import"],
  "categories": {
    "correctness": "error",
    "nursery": "error",
    "pedantic": "error",
    "perf": "error",
    "restriction": "error",
    "style": "error",
    "suspicious": "error"
  },
  "rules": {
    // We already use file extension or `type: "module"` to determine whether a file is an ES module.
    // This rule asks us to add addtional code to make it unambiguous, which is unnecessary and makes the code less clean.
    "import/unambiguous": "off",
    // Too strict.
    "import/max-dependencies": "off",
    "import/no-anonymous-default-export": "off",
    "import/no-default-export": "off",
    "import/no-named-export": "off",
    "import/no-namespace": "off",
    "import/no-nodejs-modules": "off",
    "import/no-relative-parent-imports": "off",
    "import/no-unassigned-import": "off",
    "import/prefer-default-export": "off"
  }
}
