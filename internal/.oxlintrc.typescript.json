{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error",
    "nursery": "error",
    "pedantic": "error",
    "perf": "error",
    "restriction": "error",
    "style": "error",
    "suspicious": "error"
  },
  "rules": {
    // Too strict.
    "typescript/no-explicit-any": "off",
    "typescript/no-non-null-assertion": "off",
    "typescript/no-unsafe-assignment": "off",
    "typescript/no-unsafe-argument": "off",
    "typescript/no-unsafe-call": "off",
    "typescript/no-unsafe-member-access": "off",
    "typescript/no-unsafe-return": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/prefer-readonly-parameter-types": "off",
    // Enable strict boolean expressions and void return, to prevent some common mistakes.
    "typescript/strict-boolean-expressions": ["error", { "allowString": false, "allowNumber": false, "allowNullableObject": false }],
    "typescript/strict-void-return": ["error", { "allowReturnAny": true }]
  }
}
