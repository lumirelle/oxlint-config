{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "plugins": ["jsdoc"],
  "categories": {
    "correctness": "error",
    "nursery": "error",
    "pedantic": "error",
    "perf": "error",
    "restriction": "error",
    "style": "error",
    "suspicious": "error"
  },
  "rules": {
    // XXX(Lumirelle): Add more common tag names.
    "jsdoc/check-tag-names": ["error", { "definedTags": ["credits", "experimental"] }],
    // Only enable these rules for JavaScript files.
    "jsdoc/require-param-type": "off",
    "jsdoc/require-returns-type": "off"
  },
  "overrides": [
    {
      "files": ["**/*.{,c,m}js"],
      "rules": {
        // Only enable these rules for JavaScript files.
        "jsdoc/require-param-type": "error",
        "jsdoc/require-returns-type": "error"
      }
    }
  ]
}
