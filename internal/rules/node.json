{
  "plugins": [],
  "overrides": [
    {
      "files": [
        "**/*.{,c,m}[jt]s{,x}"
      ],
      "plugins": [
        "node"
      ],
      "rules": {
        "node/handle-callback-err": [
          "error",
          "^(err|error)$"
        ],
        "node/no-exports-assign": "error",
        "node/no-new-require": "error",
        "node/no-path-concat": "error"
      }
    }
  ]
}
