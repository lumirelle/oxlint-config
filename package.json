{
  "name": "@lumirelle/oxlint-config",
  "type": "module",
  "version": "0.0.2",
  "packageManager": "bun@1.3.10",
  "description": "Lumirelle's opinionated OXLint config",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/oxlint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/oxlint-config.git"
  },
  "bugs": "https://github.com/lumirelle/oxlint-config/issues",
  "keywords": [],
  "exports": {
    "./ts": "./.oxlintrc.ts.json",
    "./vue": "./.oxlintrc.vue.json",
    "./package.json": "./package.json"
  },
  "files": [
    ".oxlintrc.ts.json",
    ".oxlintrc.vue.json",
    "internal"
  ],
  "workspaces": {
    "packages": [],
    "catalogs": {
      "dev": {
        "bumpp": "^11.0.1",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657",
        "typescript": "^5.9.3",
        "vue": "^3.5.30"
      },
      "types": {
        "@types/bun": "^1.3.10"
      },
      "check": {
        "@antfu/eslint-config": "^7.7.3",
        "@arethetypeswrong/cli": "^0.18.2",
        "eslint": "^10.0.3",
        "eslint-plugin-oxlint": "^1.56.0",
        "knip": "^5.87.0",
        "nano-staged": "^0.9.0",
        "oxlint": "^1.56.0",
        "oxlint-tsgolint": "^0.17.0",
        "publint": "^0.3.18"
      },
      "test": {
        "vitest-package-exports": "^1.1.2"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bunx @oxlint/migrate ./fixture/eslint.config.js --output-file .oxlintrc.generated.json",
    "build": "bun run ./scripts/generate-config.ts",
    "start": "bun run lint",
    "lint": "bun run --parallel 'oxlint -c .oxlintrc.json --type-aware --type-check' eslint",
    "lint:fix": "oxlint -c .oxlintrc.json --type-aware --type-check --fix && eslint --fix",
    "unused": "knip",
    "pubcheck": "bun run --parallel 'attw --pack --profile esm-only' publint",
    "gitcheck": "bun run ./scripts/check-git-status.sh",
    "check": "bun run --parallel lint unused pubcheck gitcheck",
    "test": "bun test",
    "prerelease": "bun run build && bun run --parallel check test",
    "release": "bumpp"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/oxlint-config": "file:.",
    "@types/bun": "catalog:types",
    "bumpp": "catalog:dev",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest-package-exports": "catalog:test",
    "vue": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint -c .oxlintrc.json --type-aware --type-check",
      "eslint"
    ]
  }
}
