{
  "name": "@lumirelle/oxlint-config",
  "type": "module",
  "version": "0.6.0",
  "packageManager": "bun@1.3.14",
  "description": "Lumirelle's opinionated OXLint config",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/oxlint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/oxlint-config.git"
  },
  "bugs": "https://github.com/lumirelle/oxlint-config/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    "./ts": "./.oxlintrc.ts.json",
    "./vue": "./.oxlintrc.vue.json",
    "./package.json": "./package.json"
  },
  "files": [
    ".oxlintrc.ts.json",
    ".oxlintrc.vue.json",
    "internal"
  ],
  "workspaces": {
    "packages": [],
    "catalogs": {
      "dev": {
        "bumpp": "^11.1.0",
        "vue": "^3.5.34"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/node": "^25.9.1",
        "bun-types": "^1.3.14",
        "typescript": "^6.0.3"
      },
      "baseline": {
        "@antfu/eslint-config": "^9.0.0",
        "oxlint": "^1.66.0",
        "oxlint-tsgolint": "^0.23.0"
      },
      "check": {
        "@arethetypeswrong/cli": "^0.18.2",
        "eslint": "^10.4.0",
        "eslint-plugin-oxlint": "^1.66.0",
        "knip": "^6.14.1",
        "nano-staged": "^1.0.2",
        "publint": "^0.3.21",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bunx @oxlint/migrate ./fixtures/eslint.config.js --output-file .oxlintrc.generated.json --with-nursery",
    "build": "bun run ./scripts/generate-config.ts",
    "start": "bun run lint",
    "lint": "bun run --parallel 'oxlint --config .oxlintrc.json' eslint",
    "lint:fix": "oxlint --config .oxlintrc.json --fix && eslint --fix",
    "typecheck": "tsc --build --noEmit",
    "unused": "knip-bun",
    "pubcheck": "bun run --parallel 'attw --pack --profile esm-only' publint",
    "pregitcheck": "bun run build",
    "gitcheck": "bun run ./scripts/check-git-status.sh",
    "check": "bun run --parallel lint typecheck unused pubcheck gitcheck",
    "pretest": "bun run build",
    "test": "bun test",
    "prerelease": "bun run build && bun run --parallel lint typecheck unused pubcheck gitcheck 'bun test'",
    "release": "bumpp"
  },
  "peerDependencies": {
    "@antfu/eslint-config": ">=9.0.0",
    "eslint-plugin-oxlint": ">=1.66.0",
    "oxlint": ">=1.66.0",
    "oxlint-tsgolint": ">=0.22.0"
  },
  "peerDependenciesMeta": {
    "@antfu/eslint-config": {
      "optional": true
    },
    "eslint-plugin-oxlint": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:baseline",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/node": "catalog:types",
    "bumpp": "catalog:dev",
    "bun-types": "catalog:types",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:baseline",
    "oxlint-tsgolint": "catalog:baseline",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:check",
    "typescript": "catalog:types",
    "vue": "catalog:dev"
  },
  "overrides": {
    "fflate": "0.8.2",
    "typescript": "catalog:types"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint --config .oxlintrc.json --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
