{
  "name": "@lumirelle/oxlint-config",
  "type": "module",
  "version": "0.7.0",
  "packageManager": "aube@1.17.1",
  "description": "Lumirelle's opinionated OXLint config",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/oxlint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/oxlint-config.git"
  },
  "bugs": "https://github.com/lumirelle/oxlint-config/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    "./ts": "./.oxlintrc.ts.json",
    "./vue": "./.oxlintrc.vue.json",
    "./package.json": "./package.json"
  },
  "files": [
    ".oxlintrc.ts.json",
    ".oxlintrc.vue.json",
    "internal"
  ],
  "engines": {
    "node": ">22",
    "bun": ">1"
  },
  "workspaces": {
    "packages": [],
    "catalogs": {
      "dev": {
        "bumpp": "^11.1.0",
        "vue": "^3.5.35"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/node": "^25.9.2",
        "bun-types": "^1.3.14",
        "typescript": "^6.0.3"
      },
      "baseline": {
        "@antfu/eslint-config": "^9.0.0",
        "oxlint": "^1.68.0",
        "oxlint-tsgolint": "^0.23.0"
      },
      "check": {
        "@arethetypeswrong/cli": "^0.18.3",
        "eslint": "^10.4.1",
        "eslint-plugin-oxlint": "^1.68.0",
        "knip": "^6.16.0",
        "nano-staged": "^1.0.2",
        "publint": "^0.3.21"
      },
      "test": {
        "@vitest/coverage-v8": "^4.1.8",
        "vitest": "^4.1.8"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "mise run prepare",
    "dev": "bunx @oxlint/migrate ./fixtures/eslint.config.js --output-file .oxlintrc.generated.json --with-nursery",
    "build": "bun run ./scripts/generate-config.ts",
    "oxlint": "oxlint --config .oxlintrc.json",
    "eslint": "eslint",
    "typecheck": "tsc --build --noEmit",
    "unused": "knip-bun",
    "attw": "attw --pack --profile esm-only",
    "publint": "publint",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "bumpp"
  },
  "peerDependencies": {
    "@antfu/eslint-config": ">=9.0.0",
    "eslint-plugin-oxlint": ">=1.68.0",
    "oxlint": ">=1.68.0",
    "oxlint-tsgolint": ">=0.23.0"
  },
  "peerDependenciesMeta": {
    "@antfu/eslint-config": {
      "optional": true
    },
    "eslint-plugin-oxlint": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:baseline",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/node": "catalog:types",
    "@vitest/coverage-v8": "catalog:test",
    "bumpp": "catalog:dev",
    "bun-types": "catalog:types",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:baseline",
    "oxlint-tsgolint": "catalog:baseline",
    "publint": "catalog:check",
    "typescript": "catalog:types",
    "vitest": "catalog:test",
    "vue": "catalog:dev"
  },
  "overrides": {
    "typescript": "catalog:types"
  },
  "nano-staged": {
    "*": [
      "oxlint --config .oxlintrc.json --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
