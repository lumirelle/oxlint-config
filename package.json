{
  "name": "@lumirelle/oxlint-config",
  "type": "module",
  "version": "0.12.0",
  "packageManager": "bun@1.3.14",
  "description": "Lumirelle's opinionated OXLint config",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/oxlint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/oxlint-config.git"
  },
  "bugs": "https://github.com/lumirelle/oxlint-config/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    "./ts": "./.oxlintrc.ts.json",
    "./vue": "./.oxlintrc.vue.json",
    "./package.json": "./package.json"
  },
  "files": [
    ".oxlintrc.ts.json",
    ".oxlintrc.vue.json",
    "internal"
  ],
  "engines": {
    "node": ">22",
    "bun": ">1"
  },
  "workspaces": {
    "packages": [],
    "catalogs": {
      "dev": {
        "taze": "^19.14.1",
        "vue": "^3.5.39"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.5",
        "@types/bun": "^1.3.14",
        "@types/node": "^26.1.1",
        "typescript": "^6.0.3"
      },
      "baseline": {
        "@antfu/eslint-config": "^9.1.0",
        "@oxlint/migrate": "^1.73.0",
        "oxlint": "^1.73.0",
        "oxlint-tsgolint": "^0.24.0"
      },
      "check": {
        "@arethetypeswrong/cli": "^0.18.5",
        "eslint": "^10.7.0",
        "eslint-plugin-oxlint": "^1.73.0",
        "knip": "^6.26.0",
        "publint": "^0.3.21"
      },
      "test": {
        "@vitest/coverage-v8": "^4.1.10",
        "vitest": "^4.1.10"
      },
      "release": {
        "bumpp": "^11.1.0",
        "changelogithub": "^14.0.0",
        "npm": "^12.0.1",
        "pkg-pr-new": "^0.0.75"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@antfu/eslint-config": ">=9.1.0",
    "eslint-plugin-oxlint": ">=1.73.0",
    "oxlint": ">=1.73.0",
    "oxlint-tsgolint": ">=0.23.0"
  },
  "peerDependenciesMeta": {
    "@antfu/eslint-config": {
      "optional": true
    },
    "eslint-plugin-oxlint": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:baseline",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@oxlint/migrate": "catalog:baseline",
    "@types/bun": "catalog:types",
    "@types/node": "catalog:types",
    "@vitest/coverage-v8": "catalog:test",
    "bumpp": "catalog:release",
    "changelogithub": "catalog:release",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "npm": "catalog:release",
    "oxlint": "catalog:baseline",
    "oxlint-tsgolint": "catalog:baseline",
    "pkg-pr-new": "catalog:release",
    "publint": "catalog:check",
    "taze": "catalog:dev",
    "typescript": "catalog:types",
    "vitest": "catalog:test",
    "vue": "catalog:dev"
  },
  "overrides": {
    "typescript": "catalog:types"
  }
}
