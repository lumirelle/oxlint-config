{
  // Code Quality
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "never",
    "source.fixAll.eslint": "never",
    "source.organizeImports": "never"
  },
  "oxc.typeAware": true,
  "eslint.runtime": "bun",
  "eslint.execArgv": ["-b"],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml",
    "toml",
    "xml",
    "css",
    "postcss",
    "scss",
    "sass",
    "less"
  ],

  "files.associations": {
    ".oxlintrc.*.json": "jsonc"
  }
}
